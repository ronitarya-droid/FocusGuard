<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        FocusGuard is an always-dark, edge-to-edge, no-action-bar app. The visual
        system lives in Ui.kt (all views built in code); this theme only wires up
        window chrome, the activity transition choreography, and the dialog skin so
        system popups match the in-app surfaces instead of flashing a white box.
    -->
    <style name="Theme.FocusGuard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/fg_bg</item>

        <!-- Edge-to-edge: transparent system bars, content draws behind them.
             Activities apply insets in code (Ui.scaffold). -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>

        <!-- Smooth, choreographed activity transitions. -->
        <item name="android:windowAnimationStyle">@style/FgWindowAnimation</item>

        <!-- Material accent + dark dialog skin. -->
        <item name="colorPrimary">@color/fg_accent</item>
        <item name="android:colorAccent">@color/fg_accent</item>
        <item name="android:alertDialogTheme">@style/Theme.FocusGuard.Dialog</item>
        <item name="alertDialogTheme">@style/Theme.FocusGuard.Dialog</item>
    </style>

    <style name="FgWindowAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/fg_enter</item>
        <item name="android:activityOpenExitAnimation">@anim/fg_exit</item>
        <item name="android:activityCloseEnterAnimation">@anim/fg_pop_enter</item>
        <item name="android:activityCloseExitAnimation">@anim/fg_pop_exit</item>
    </style>

    <!-- Dark dialog so confirm/unblock popups match the app surfaces. Platform
         parent (Theme.Material.Dialog.Alert) — the activities use
         android.app.AlertDialog, so this must be a platform dialog theme, not a
         Material3 ThemeOverlay. -->
    <style name="Theme.FocusGuard.Dialog" parent="@android:style/Theme.Material.Dialog.Alert">
        <item name="android:colorBackground">@color/fg_surface_hi</item>
        <item name="android:textColorPrimary">@color/fg_text</item>
        <item name="android:textColorSecondary">@color/fg_text_dim</item>
        <item name="android:colorAccent">@color/fg_accent</item>
        <item name="android:windowTitleStyle">@style/FgDialogTitle</item>
    </style>

    <style name="FgDialogTitle" parent="@android:style/TextAppearance.Material.DialogWindowTitle">
        <item name="android:textColor">@color/fg_text</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
